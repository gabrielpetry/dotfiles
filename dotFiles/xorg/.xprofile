#!/bin/bash
source "${HOME}/.profile" & # source .profile variables
sxhkd & # start hotkey daemon on lightdm start
unclutter & # no mouse when iddle
rocketchat-desktop &
fusuma & # Start fusuma for multigestures on lightdm boot
"${HOME}"/petryfiles/scripts/update_mpris2.py & # Start the update_mpris2 daemon
spotify & # initiatiate spotify always
chromium & # Start a chrome session
sxhkd -c "${HOME}"/.config/sxhkd/sxhkdrc &
fusuma &
compton &
