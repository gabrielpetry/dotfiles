    /**
     * Popula o atributo $this->apache_conf com o(s) vhosts(s) do servidor
     *
     * @return bool
     */
    public function recria_apache_conf()
    {
        //Se for um domínio com supermapeamento pra outro
        if($this->dominio_conf){
            $this->dominio_conf = $this->get_dominio_principal_supermapeamento();
        }

        $this->badUa = $this->getUserAgent('bad');
        $this->goodUA = $this->getUserAgent('good');

        //botamos os templates de vhost na memoria
        $this->busca_vhost_templates();

        if ($this->main_conf) {
            $this->config_inicial();

            //Config SSL
            $conf[] = 'ServerTokens Prod';
            $conf[] = 'ServerSignature Off';
            $conf[] = 'TraceEnable off';
            $this->apache_conf .= implode("\n", $conf) . "\n\n";

            //Busca Bloqueados via Painel
            $this->busca_bloqueados_painel();
            $this->config_bloqueado();

            //Vhost de Stats
            $this->configura_proxy_stats();

            if ($this->main_conf == '2') {
                return true;
            }
        }

        $this->dominios = $this->get_lista_dominios_servidor(true);
        if ($this->dbKinghost->error) {
            die('Erro ' . __LINE__ . ' ao efetuar query');
        }

        //Adicionar os domínios de supermapeamentos no array de domínios
        $this->get_lista_supermapeamentos_servidor();

        /*
         * Pegar todos os dominios da dcli
        * Criar um array com todos os dominios aonde a chave é iddominio (multidimensional -> idcliente)
        * separar os ids de dominio e por em formato de um "IN" (query)
        *
        * Consulta em todas as tabelas usando IdDominio pelo IN e tipo (R ou C)
        *
        * Reformular config_individual_dominio pra pegar esses dados
        */

        //Cria pilhas de dados principais
        $this->cria_pilha_dominios();
        $this->cria_pilha_bloqueios();
        $this->cria_pilha_useragent();
        $this->cria_pilha_tags_original();
        $this->cria_pilha_diretivas_original();
        $this->cria_pilha_planos();

        $validos = array(
            'subdominios',
            'mapeamentos',
            'ipdedicado',
            'tomcat',
            'webapps',
            'rails',
            'wsgi',
            'zope',
            'pagespeed',
            'pagespeed_stats',
            'nodejs',
            'max_execution_time'
        );
        foreach ($validos as $tipo) {
            $this->cria_pilha($tipo);
        }

        //Patch SNI
        $this->cria_pilha_ssl();
        $this->cria_pilha_ssl_sni();

        //Novo Httpd.original
        //$this->busca_linhas_httpd_original();

        //Esses dados serao usados para retorno da API
        $this->dados_ssl = array();
        $this->dados_pagespeed = array();

        foreach ($this->dominios as $dados_dominio) {

            /*
             * Bloqueios :: INICIO
             * Padrao: #bloqueado:campo:valor
             */
            if ($dados_dominio['Ativo'] != '1') {
                $conf = '#bloqueado:Ativo:' . $dados_dominio['Ativo'];
                $this->apache_conf .= $conf;

                if (is_array($this->multi_domain)) {
                    $this->multi_domain[$dados_dominio['Dominio']] = $conf;
                }

                continue;
            }

            if ($dados_dominio['BloqueioTrafego'] == '2') {
                $conf = '#bloqueado:bloqueiotrafego:' . $dados_dominio['BloqueioTrafego'];
                $this->apache_conf .= $conf;

                if (is_array($this->multi_domain)) {
                    $this->multi_domain[$dados_dominio['Dominio']] = $conf;
                }

                continue;
            }

            if (is_array($this->pilha_bloqueios[$dados_dominio['Id']])) {
                $conf = '#bloqueado:ServicosHostingConfigBloqueioWeb:' . $this->pilha_bloqueios[$dados_dominio['Id']][0]['id'];
                $this->apache_conf .= $conf;

                if (is_array($this->multi_domain)) {
                    $this->multi_domain[$dados_dominio['Dominio']] = $conf;
                }

                continue;
            }
            /*
             * Bloqueios :: FIM
            */

            $this->dados_dominio = $dados_dominio;
            //$this->dados_dominio['Username'] = substr(current(explode(".", $this->dados_dominio['Dominio'])), 0, 31);
            $this->dados_dominio['Username'] = $this->getUsernameFromDomain($this->dados_dominio['Dominio']);

            if($this->dados_dominio['DominioSuperMapeamento']){
                //$this->dados_dominio['UsernameSuperMapeamento'] = substr(current(explode(".", $this->dados_dominio['DominioSuperMapeamento'])), 0, 31);
                $this->dados_dominio['UsernameSuperMapeamento'] = $this->getUsernameFromDomain($this->dados_dominio['DominioSuperMapeamento']);
            }

            if ($this->sitebuilder) {
                if ($dados_dominio['username']) {
                    $this->dados_dominio['Username'] = $dados_dominio['username'];
                }

                //Mapeamentos
                $map = $this->pilha_mapeamentos[$this->dados_dominio['Id']];
                $map = (is_array($map)) ? $map : array();

                $mapeamentos = '';
                foreach ($map as $dadosMapeamento) {
                    $mapeamentos .= " {$dadosMapeamento['Mapeamento']} *.{$dadosMapeamento['Mapeamento']}";
                }

                $conf_passenger = '';
                //if($this->servidor_tem_suporte('RAILS')) $conf_passenger = $this->get_config_passenger();

                $replace_in = array(
                    '%DOMINIO%',
                    '%USERNAME%',
                    '%MAPEAMENTOS%',
                    '%IPS_LISTEN%',
                    '%EXCECOES%',
                    '%MOD_PASSENGER%'
                );
                $replace_out = array(
                    $this->dados_dominio['Dominio'],
                    $this->dados_dominio['Username'],
                    trim($mapeamentos),
                    '*:80',
                    '',
                    $conf_passenger
                );

                $conf = str_replace($replace_in, $replace_out, $this->templates_vhosts['DOMINIO-SITEBUILDER']) . "\n\n";
                $this->apache_conf .= $conf;

                if (is_array($this->multi_domain)) {
                    $vhost_atual = '';
                    if (strlen($this->multi_domain[$this->dados_dominio['Dominio']])) {
                        $vhost_atual = $this->multi_domain[$this->dados_dominio['Dominio']] . "\n\n";
                    }

                    $vhost_atual .= str_replace("\r\n", "\n", $conf);
                    $this->multi_domain[$this->dados_dominio['Dominio']] = $vhost_atual;
                }

                continue;
            }

            //Config Bloqueio
            $config_badUa = $this->pilha_useragent[$this->dados_dominio['Id']]['Valor'];
            $this->user_agent_row = (strlen($config_badUa) > 3) ? explode(',', $config_badUa) : array();

            $this->dominiosFicha[$this->dados_dominio['IdCliente']] = $this->pilha_dominios[$this->dados_dominio['IdCliente']];
            if (strlen($this->dominio_conf)) {
                $this->busca_dominios_ficha();
            }

            $id_dominio_busca = $this->dados_dominio['Id'];
            if($this->dados_dominio['IdDominioSuperMapeamento']){
                $id_dominio_busca = $this->dados_dominio['IdDominioSuperMapeamento'];
            }

            /**
             * Para caso de supermapeamento:
             * $id_dominio_busca = vai conter sempre o domínio destino
             * $this->dados_dominio['Id'] = Contém o ID do mapeamento (origem)
             *
             * Se não for supermapeamento:
             * $id_dominio_busca = Id do domínio
             */

            $this->adicionais = array(
                'subdominios'           => $this->pilha_subdominios[$this->dados_dominio['Id']], //TESTAR
                'ssl'                   => $this->pilha_ssl[$this->dados_dominio['Id']], // MANTER SEMPRE $this->dados_dominio['Id'] (by braz)

                'mapeamentos'           => $this->pilha_mapeamentos[$id_dominio_busca],
                'ip_adicional'          => $this->pilha_ipdedicado[$id_dominio_busca],
                'tomcat'                => $this->pilha_tomcat[$id_dominio_busca],
                'webapps'               => $this->pilha_webapps[$id_dominio_busca],
                'rails'                 => $this->pilha_rails[$id_dominio_busca],
                'wsgi'                  => $this->pilha_wsgi[$id_dominio_busca],
                'zope'                  => $this->pilha_zope[$id_dominio_busca],
                'pagespeed'             => $this->pilha_pagespeed[$id_dominio_busca],
                'pagespeed-stats'       => $this->pilha_pagespeed_stats[$id_dominio_busca],
                'nodejs'                => $this->pilha_nodejs[$id_dominio_busca],
                'max_execution_time'    => $this->pilha_max_execution_time[$id_dominio_busca]
            );

            if ($this->cliente) { 
                $this->adicionais['dados_plano'] = $this->pilha_planos[$this->dados_dominio['Plano']];

                $this->dados_dominio['Java']        = $this->dados_dominio['Java'];
                //Caso não seja opcional, pega do plano
                if ($this->adicionais['dados_plano']['Java'] != 2) {
                    $this->dados_dominio['Java']    = $this->adicionais['dados_plano']['Java'];    
                }
                $this->dados_dominio['Plataforma']  = $this->adicionais['dados_plano']['Plataforma'];
                $this->dados_dominio['Plano']       = $this->adicionais['dados_plano']['Plano'];
                $this->dados_dominio['Wsgi']        = $this->adicionais['dados_plano']['Wsgi'];
                $this->dados_dominio['Rails']       = $this->adicionais['dados_plano']['Rails'];
                $this->dados_dominio['Zope']        = $this->adicionais['dados_plano']['Zope'];
                $this->dados_dominio['Nodejs']      = $this->adicionais['dados_plano']['Nodejs'];

                if ($this->dados_dominio['PHP'] == null) {
                    $this->dados_dominio['PHP'] = $this->adicionais['dados_plano']['PHP'];
                }
            }
            if ($this->revenda) {
                $this->dados_dominio['PHP'] = $this->dados_dominio['Php'];
            }

            $conf = $this->configura_vhost();
            $this->apache_conf .= $conf;

            //Subdominio como dominio
            $this->temSubdominio = $this->subdominioExcecao();

            if (is_array($this->multi_domain)) {
                $vhost_atual = '';
                if (strlen($this->multi_domain[$this->dados_dominio['Dominio']])) {
                    $vhost_atual = $this->multi_domain[$this->dados_dominio['Dominio']] . "\n\n";
                }

                $vhost_atual .= str_replace("\r\n", "\n", $conf);
                $this->multi_domain[$this->dados_dominio['Dominio']] = $vhost_atual;
                $this->multi_subdomain[$this->dados_dominio['Dominio']] = $this->temSubdominio;
            }

            if (is_array($this->adicionais['ssl']) AND count($this->adicionais['ssl'])) {
                $this->dados_ssl[$this->dados_dominio['Dominio']] = $this->adicionais['ssl'];
            }

            if (is_array($this->adicionais['pagespeed-stats']) AND count($this->adicionais['pagespeed-stats'])) {
                $this->dados_pagespeed[$this->dados_dominio['Dominio']] = $this->adicionais['pagespeed-stats'];
            }
        }

        //busca dominios migrados para proxy reverso
        if ($this->proxy_conf) {
            $this->buscaMigradosProxyReverso();
        }

    }

    function subdominioExcecao()
    {
        if (!$this->dados_dominio) {
            return false;
        }
        if (substr_count($this->dados_dominio['Dominio'], 'uni5.net')) {
            return false;
        }
        if (substr_count($this->dados_dominio['Dominio'], 'kinghost.net')) {
            return false;
        }
        if (!is_array($this->dominiosFicha[$this->dados_dominio['IdCliente']])) {
            return false;
        }

        foreach ($this->dominiosFicha[$this->dados_dominio['IdCliente']] as $d) {
            if (substr_count($d['Dominio'], ".{$this->dados_dominio['Dominio']}")) {
                return true;
            }
        }
        return false;
    }

    function busca_dominios_ficha()
    {
        if (is_array($this->dominiosFicha[$this->dados_dominio['IdCliente']]) && count($this->dominiosFicha[$this->dados_dominio['IdCliente']]) > 1) {
            return $this->dominiosFicha;
        }

        $tabela = ($this->revenda) ? 'ServicosHostingDRev' : 'ServicosHostingDCli';
        $sql = "SELECT * FROM `{$tabela}` WHERE `IdCliente`='{$this->dados_dominio['IdCliente']}' AND `Servidor`='{$this->hostname}'";

        $res = $this->dbKinghost->get_results($sql, true);
        $res = (is_array($res)) ? $res : array();

        $retorno = array();
        foreach ($res as $dados_dominio) {
            $retorno[$dados_dominio['Id']] = $dados_dominio;
        }

        $this->dominiosFicha[$this->dados_dominio['IdCliente']] = $retorno;

        return $this->dominiosFicha;
    }

    function buscaMigradosProxyReverso()
    {
        if (!is_array($this->templates_vhosts)) {
            $this->busca_vhost_templates();
        }

        $dados = $this->getDominiosMigrados();
        $dados = (is_array($dados)) ? $dados : array();

        foreach ($dados as $dadosDominio) {
            if ($dadosDominio['Servidor'] == $this->hostname) {
                continue;
            }

            $variaveis['DOMINIO'] = $dadosDominio['Dominio'];
            $variaveis['IP_EXT'] = $dadosDominio['IpExterno'];

            $this->apache_conf .= $this->template($variaveis, $this->templates_vhosts['PROXYMIGRADOS']) . "\n\n";
        }
    }

    function monta_excecoes_vhost($subdominio = 'www')
    {
        $inicio = '';
        $fim = '';
        $retorno = '';


        //Montamos as diretivas de primeiro nivel
        $dados = $this->pilha_diretivas_original[$this->dados_dominio['Id']][$subdominio];
        $dados = (is_array($dados)) ? $dados : array();

        foreach ($dados as $linha) {
            if ($linha['idTag'] !== 0) {
                $tags[$linha['idTag']][] = $linha;
                continue;
            }

            $retorno .= "{$linha['chave']} {$linha['valor']}\n";
        }

        //vamos para as tags
        $dados = $this->pilha_tags_original[$this->dados_dominio['Id']][$subdominio];
        $dados = (is_array($dados)) ? $dados : array();

        foreach ($dados as $linha) {
            if (!is_array($tags[$linha['id']])) {
                continue;
            }

            $retorno .= "\n<{$linha['chave']} {$linha['valor']}>\n";

            foreach ($tags[$linha['id']] as $tag) {
                $retorno .= "   {$tag['chave']} {$tag['valor']}\n";
            }

            $retorno .= "</{$linha['chave']}>\n ";
        }

        if (strlen($retorno)) {
            $inicio = "## Dados das tabelas ServicosHostingHttpdDiretivas e ServicosHostingHttpdTags\n";
            $fim = "## FIM diretivas e tags\n";
        }

        return $inicio . $retorno . $fim;
    }

    function get_config_mod_pagesped()
    {
        if (is_array($this->adicionais['pagespeed']) == false OR count($this->adicionais['pagespeed']) == false) {
            return '';
        }

        $powered = ($this->cliente) ? 'ModPagespeedXHeaderValue "Powered By KingHost and mod_pagespeed"' : '';

        $defaultFilters = array(
            'add_head',
            'combine_css',
            'rewrite_css',
            'combine_javascript',
            'sprite_images',
            'remove_quotes',
            'trim_urls',
            'flatten_css_imports',
            'rewrite_images',
            'move_css_to_head',
            'collapse_whitespace',
            'remove_comments',
            'combine_heads',
            'convert_meta_tags',
            'dedup_inlined_images',
            'elide_attributes',
            'move_css_above_scripts'
        );

        $activeFilters = explode(',', $this->adicionais['pagespeed'][0]['Valor']);
        $disableFilters = array_diff($defaultFilters, $activeFilters);
        if(is_array($disableFilters) and count($disableFilters)) $txtDisableFilters = implode(',', $disableFilters);

        $txt_filters = (strlen($this->adicionais['pagespeed'][0]['Valor'])) ?
            $this->adicionais['pagespeed'][0]['Valor'] : 'add_head,combine_css,rewrite_css,combine_javascript,sprite_images,remove_quotes,trim_urls,flatten_css_imports,rewrite_images,move_css_to_head,combine_heads';


        $txt_stats = '';
        if (is_array($this->pilha_pagespeed_stats) AND count($this->pilha_pagespeed_stats)) {
            $txt_stats = "
            ModPagespeedStatistics on

            <Location /mod_pagespeed_statistics>
                RewriteEngine Off
                allow from all

                SetHandler mod_pagespeed_statistics
                
                AuthName                        'Informe as Credenciais de acesso'
                AuthType                        Basic
                AuthGroupFile                   /dev/null
                AuthUserFile /home/{$this->dados_dominio['Username']}/.htpasswd.pagespeed
                Require valid-user
            </Location>
                  ";

            $txt_filters = 'add_instrumentation,' . $txt_filters;
        }

        $conf = '
        <IfModule pagespeed_module>
            ' . $powered . '
            ModPagespeed                      on
            ModPagespeedEnableFilters ' . $txt_filters . '
            ' . (isset($txtDisableFilters) ? 'ModPagespeedDisableFilters ' . $txtDisableFilters  : '') . '
            ' . $txt_stats . '
        </IfModule>
               ';

        return $conf;
    }

    public function get_conf_access_log($dominio){
        return '
            <IfModule log_config_module>
                 LogFormat "www.'.$dominio.' %h %l %u %t \"%r\" %>s %b \"%{Referer}i\" \"%{User-Agent}i\" %{remote}p"
                 TransferLog /home/logs/access_log
            </IfModule>
        ';
    }

