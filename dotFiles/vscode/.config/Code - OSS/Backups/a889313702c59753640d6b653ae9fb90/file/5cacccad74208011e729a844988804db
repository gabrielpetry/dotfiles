    public function get_linha($idDominio, $rede)
    {
        $redes_validas = array('R', 'C');
        $rede = strtoupper($rede);
        if (!in_array($rede, $redes_validas)) {
            $rede = 'C';
        }

        $tabela_dominio = ($rede == 'C') ? 'ServicosHostingDCli' : 'ServicosHostingDRev';

        $sql = "
                        SELECT
                        h.*,
                        d.Dominio
                        FROM `ServicosHostingHttpdOriginal` h, {$tabela_dominio} d
                        WHERE h.`idCliente` = d.`IdCliente`
                        AND h.`idDominio` = d.`Id`
                        AND h.`idDominio`='{$idDominio}'
                        AND h.`tipo`='{$rede}'
                ";

        $r = $this->dbKinghost->get_row($sql, true);
        return (is_array($r)) ? $r : array();
    }

    public function get_linha_dominio($idDominio, $rede)
    {
        $rede = strtoupper($rede);
        if (!preg_match('/^(R|C)$/', $rede)) {
            $rede = 'C';
        }

        $tabela_dominio = ($rede == 'C') ? 'ServicosHostingDCli' : 'ServicosHostingDRev';
        $sql = "SELECT * FROM `{$tabela_dominio}` WHERE Id='{$idDominio}'";

        return $this->dbKinghost->get_row($sql);
    }

    function salva_linha($dados)
    {
        $dadosDominio = $this->get_linha_dominio($dados['idDominio'], $dados['tipo']);
        if (!$dadosDominio) {
            return array(0, 'Dominio não localizado');
        }

        $dados['idCliente'] = $dadosDominio['IdCliente'];

        $sql = forma_insert($dados, 'ServicosHostingHttpdOriginal');
        $attr = 'insert_id';

        if ($dados['idCliente']) {
            $linha = $this->get_linha($dados['idDominio'], $dados['tipo']);
            if (is_numeric($linha['id'])) {
                $sql = forma_update($dados, 'ServicosHostingHttpdOriginal', "`id`='{$linha['id']}'");
                $attr = 'affected_rows';
            }
        }

        $this->dbKinghost->alter_sql($sql);
        $ret = array($this->dbKinghost->$attr);

        if ($ret > 0) {
            return array($ret);
        }
        return array(false, 'Erro ao gravar dados');
    }

