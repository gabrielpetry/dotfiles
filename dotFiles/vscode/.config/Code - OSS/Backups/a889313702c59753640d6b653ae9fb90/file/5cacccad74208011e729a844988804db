    private function getUserAgent($tipo)
    {
        $permitidos = Array('bad', 'good');
        $tipo = (in_array($tipo, $permitidos)) ? $tipo : 'bad'; // padrao = bad

        if (!is_array($this->pilha_user_agent)) {
            $sql = "SELECT * FROM `useragentControl`";
            $res = $this->dbKinghost->get_results($sql);
            $this->pilha_user_agent = (is_array($res)) ? $res : array();
        }

        $res = array();
        foreach ($this->pilha_user_agent as $linha) {
            if ($linha['tipo'] != $tipo) {
                continue;
            }
            $res[] = $linha;
        }

        foreach ($res as $dados) {
            $r[$dados['descricao']] = $dados['string'];
        }
        $r = (is_array($r)) ? $r : array();

        return $r;
    }

