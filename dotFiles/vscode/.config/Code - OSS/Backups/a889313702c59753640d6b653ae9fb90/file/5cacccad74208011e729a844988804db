    function cria_pilha($tipo)
    {

        if (!$this->pilha_in) {
            $this->cria_pilha_dominios();
        }

        $array_map = array(
            'subdominios'        => 'ServicosHostingSubdominios',
            'mapeamentos'        => 'ServicosHostingMapeamentos',
            'ipdedicado'         => 'ServicosHostingIpDedicado',
            'tomcat'             => 'ServicosHostingTomcat',
            'webapps'            => 'ServicosHostingWebapps',
            'rails'              => 'ServicosHostingRails',
            'wsgi'               => 'ServicosHostingWsgi',
            'zope'               => 'ServicosHostingZope',
            'pagespeed'          => 'ServicosHostingConfigWeb',
            'pagespeed_stats'    => 'ServicosHostingConfigWeb',
            'nodejs'             => 'ServicosHostingNodejsApps',
            'max_execution_time' => 'ServicosHostingPhp'
        );

        $tabela = $array_map[$tipo];
        if (!$tabela) {
            return false;
        }

        if (!strlen($this->pilha_in)) {
            $var = "pilha_{$tipo}";
            $this->$var = false;
            return false;
        }

        switch ($tipo) {
            case 'max_execution_time':
                $sql = "SELECT * FROM `{$tabela}` WHERE `IdDominio` IN({$this->pilha_in}) AND `rede`='$this->rede_letra' AND `Chave`='max_execution_time'";
                break;

            case 'pagespeed':
                $sql = "SELECT * FROM `{$tabela}` WHERE `IdDominio` IN({$this->pilha_in}) AND `tipoDominio`='$this->rede_letra' AND `Tipo`='pagespeed'";
                break;

            case 'pagespeed_stats':
                $sql = "SELECT * FROM `{$tabela}` WHERE `IdDominio` IN({$this->pilha_in}) AND `tipoDominio`='$this->rede_letra' AND `Tipo`='pagespeed-stats'";
                break;

            case 'nodejs':
                $sql = "SELECT * FROM `{$tabela}` WHERE `IdDominio` IN({$this->pilha_in}) AND `AcessoWeb`='SIM' AND `AppStatus`='ATIVO' ORDER BY `AppUri` DESC";
                break;

            case 'subdominios':
                //$sql = "SELECT * FROM `{$tabela}` WHERE `IdDominio` IN({$this->pilha_in}) AND `Tipo`='$this->rede_letra'";
                $sql = "SELECT sub.*, va.subdominio as varnish FROM
                 `ServicosHostingSubdominios` as sub
                 LEFT JOIN ServicosHostingVarnish as va
                 ON  va.IdDominio = sub.IdDominio
                 AND va.IdCliente = sub.IdCliente
                 AND va.Tipo = '$this->rede_letra'
                 AND va.subdominio = sub.subdominio
                 AND va.subdominio != 'www'
                 AND va.subdominio != '@'
                 AND va.Ativo = 'Sim'
                 where sub.IdDominio in ({$this->pilha_in})
                  And sub.Tipo='$this->rede_letra'";
                break;

            case 'ipdedicado':
                $sql = "SELECT ip.* 
                    FROM ServicosHostingIpDedicado as ip
                    LEFT JOIN ServicosHostingVarnish as var
                            ON var.IdDominio = ip.IdDominio
                            AND (
                            	ip.SubDominio =  var.subdominio
                            	OR ip.SubDominio = '@' AND var.subdominio = 'www'
                            	OR ip.SubDominio = 'www' AND var.subdominio = '@'
                            	AND ip.ssl =1
                            )
                            AND var.Ativo = 'Sim'
                    WHERE ip.`IdDominio` 
                    IN({$this->pilha_in}) 
                    AND ip.`Tipo`='{$this->rede_letra}'
                    AND var.tipoVarnish is null";
                break;

            default:
                $sql = "SELECT * FROM `{$tabela}` WHERE `IdDominio` IN({$this->pilha_in}) AND `Tipo`='$this->rede_letra'";
                break;
        }


        $res = $this->db->get_results($sql, true);
        $res = (is_array($res)) ? $res : array();

        $tipos_row = array('zope', 'tomcat'); //Tipos que o result tem que ser uma row e nao um resultset

        $r = array();
        if (in_array($tipo, $tipos_row)) {
            foreach ($res as $dados) {
                $r[$dados['IdDominio']] = $dados;
            }
        } else {
            foreach ($res as $dados) {
                $r[$dados['IdDominio']][] = $dados;
            }
        }

        //Nome do atributo que vai gravar o result
        $var = "pilha_{$tipo}";
        $this->$var = $r;
        return $this->$var;
    }

