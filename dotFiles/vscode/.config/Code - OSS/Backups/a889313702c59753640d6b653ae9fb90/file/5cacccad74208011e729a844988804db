    /**
     * Retorna os dados do campo "servico" da tabela "ServidorServicos" em um array
     * @return array
     */
    private function _get_services(){
        $raw_services = $this->server_dados['servico'];
        $services = explode(',', $raw_services);
        return (is_array($services)) ? $services : array();
    }

    /**
     * Retorna a versão do PHP mais nova configurada na ServidorServicos
     * @return float
     */
    private function _get_last_php(){
        $services = $this->_get_services();

        $last_version = 5.3;
        foreach ($services as $service) {
            if (!preg_match("/^PHP([0-9]{1,2}\.[0-9])$/", $service, $output)) {
                continue;
            }

            $version = (float) $output[1];
            if($version > $last_version){
                $last_version = $version;
            }
        }

        return $last_version;
    }

    private function fpm_ping_config_mod_fastcgi()
    {
        $return = '';
        $services = $this->_get_services();
        foreach ($services as $service) {
            if (!preg_match("/^PHP([0-9]{1,2}\.[0-9])$/", $service, $output)) {
                continue;
            }

            $version = $output[1];
            if ((float)$version < 5.4) {
                continue;
            }

            $return .= "
                Action php{$version}-fcgi /php{$version}-fcgi
                Alias /php{$version}-fcgi /var/run/www-apache{$version}-fcgi
                FastCgiExternalServer /var/run/www-apache{$version}-fcgi -appConnTimeout 10 -idle-timeout 10 -socket /var/run/fastcgi/{$this->hostname}-php{$version}.socket -pass-header Authorization
                
                <Location \"/fpm-{$version}-ping\">
                        Order deny,allow
                        Allow from all
                        SetHandler php{$version}-fastcgi-virt
                        Action php{$version}-fastcgi-virt /php{$version}-fcgi virtual
                </Location>                
            ";
        }

        return $return;
    }

    private function fpm_ping_config_mod_proxy_fcgi()
    {
        $return = '';

        $raw_services = $this->server_dados['servico'];
        $services = explode(',', $raw_services);
        $services = (is_array($services)) ? $services : array();

        foreach ($services as $service) {
            if (!preg_match("/^PHP([0-9]{1,2}\.[0-9])$/", $service, $output)) {
                continue;
            }

            $version = $output[1];
            if ((float)$version < 5.4) {
                continue;
            }

            $return .= "
                <Location \"/fpm-{$version}-ping\">
                    <Ifmodule security2_module>
                        SecRuleEngine Off
                    </Ifmodule>
                    Order deny,allow
                    Allow from all
                    ProxyPass \"unix:/var/run/fastcgi/{$this->hostname}-php{$version}.socket|fcgi://{$this->hostname}-php{$version}/\"
                </Location>
            ";
        }

        return $return;
    }

