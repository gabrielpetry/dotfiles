    function busca_linhas_httpd_original()
    {
        require_once('class.dominio.php');

        if ($this->pilha_in === false) {
            $this->cria_pilha_dominios();
        }

        $sql = "SELECT * FROM `ServicosHostingHttpdOriginal` WHERE `tipo`='{$this->rede_letra}' AND `servidor`='{$this->hostname}'";

        if (preg_match('/^webmail-node/', $this->hostname)) {
            $sql = "SELECT * FROM `ServicosHostingHttpdOriginal` WHERE `tipo`='{$this->rede_letra}' AND `servidor` IN('{$this->hostname}', 'webmail-node')";
        }

        if ($this->dominio_conf) {
            $sql = "
                                SELECT o.* FROM `ServicosHostingHttpdOriginal` o, `{$this->config['tabela_dominio']}` d
                                WHERE o.`tipo`='{$this->rede_letra}'
                                AND o.`servidor`='{$this->hostname}'
                                AND d.`Servidor`='{$this->hostname}'
                                AND d.`Dominio`='{$this->dominio_conf}'
                                AND o.idDominio = d.Id
                                AND o.idCliente = d.IdCliente
                        ";
        }

        $rows = $this->dbKinghost->get_results($sql, true);
        $rows = (is_array($rows)) ? $rows : array();

        $registro_httpdoriginal = '';
        foreach ($rows as $row) {
            //print_r($row);

            //Pegamos os IP's do vhost
            $txt_ip = '*:80';
            if (strlen($row['ips']) > 5) {
                $array_ips = unserialize($row['ips']);
                if (is_array($array_ips)) {
                    $txt_ip = '';
                    foreach ($array_ips as $linha) {
                        if (strpos($linha['ip'], ':')) {
                            $txt_ip .= "[{$linha['ip']}]:{$linha['porta']} ";
                            continue;
                        }
                        $txt_ip .= "{$linha['ip']}:{$linha['porta']} ";
                    }
                }
            }

            /*
             * %USERNAME%
            * %DOMINIO%
            * %CRTPATH%
            * %KEYPATH%
            * %PEMPATH%
            */

            //echo $row['vhost']."\n\n";
            //print_r($row);
            $buffer = '';

            //Forcar idCliente e idDOminio numericos
            $row['idCliente'] = intval($row['idCliente']);
            $row['idDominio'] = intval($row['idDominio']);

            //Patch dominios removidos ou invalidos
            if ($row['idCliente'] > 0 AND $row['idDominio'] > 0) {
                $obj = new Dominio($row['idCliente'], $row['idDominio']);
                if (!is_array($obj->dadosDominio)) {
                    $vhost_tmp = "## ATENÇÃO ##\n";
                    $vhost_tmp .= "## REGISTRO #{$row['id']} inválidona tabela ServicosHostingHttpdOriginal\n";
                    $vhost_tmp .= "## Provavelmente esse domínio foi removido do sistema. VERIFICAR\n";
                    $vhost_tmp .= "## idCliente: {$row['idCliente']}\n";
                    $vhost_tmp .= "## idDominio: {$row['idDominio']}";

                    $row['vhost'] = $vhost_tmp;
                    $row['idCliente'] = 0;
                    $row['idDominio'] = 0;
                }
            }

            if ($row['servidor'] == 'webmail-node') {
                $in = array('%HOSTNAME%', '%REDE%');
                $out = array($this->hostname, $this->rede);


                $vhost = "#\n# Registro da tabela ServicosHostingHttpdOriginal ID:{$row['id']}\n#\n";
                $vhost .= trim(stripslashes(str_replace($in, $out, $row['vhost']))) . "\n\n";
                $buffer .= $vhost;

                //Patch novo apache_conf
                $this->registro_httpd_original .= $vhost;

                continue;
            }

            //Hostnames genericos
            if ($row['idCliente'] == 0 OR $row['idDominio'] == 0) {
                $in = array('%IPS%', '%SERVERNAME%');
                $out = array($txt_ip, $this->hostname_full);

                if (strlen($row['crtPath']) > 4) {
                    $in[] = '%CRTPATH%';
                    $out[] = $row['crtPath'];
                }

                if (strlen($row['keyPath']) > 4) {
                    $in[] = '%KEYPATH%';
                    $out[] = $row['keyPath'];
                }

                if (strlen($row['pemPath']) > 4) {
                    $in[] = '%PEMPATH%';
                    $out[] = $row['pemPath'];
                }

                if (strlen($row['username'])) {
                    $in[] = '%USERNAME%';
                    $out[] = $row['username'];
                }

                $vhost = "#\n# Registro da tabela ServicosHostingHttpdOriginal ID:{$row['id']}\n#\n";
                $vhost .= trim(stripslashes(str_replace($in, $out, $row['vhost']))) . "\n\n";
                $buffer .= $vhost;

                //Patch novo apache_conf
                $this->registro_httpd_original .= $vhost;
                continue;
            }

            //Hostnames com idCliente e idDominio
            $in = array('%IPS%', '%SERVERNAME%', '%DOMINIO%', '%USERNAME%');
            $out = array($txt_ip, $this->hostname_full, $obj->dadosDominio['Dominio'], $obj->dadosDominio['Username']);

            if (strlen($row['crtPath']) > 4) {
                $in[] = '%CRTPATH%';
                $out[] = $row['crtPath'];
            }

            if (strlen($row['keyPath']) > 4) {
                $in[] = '%KEYPATH%';
                $out[] = $row['keyPath'];
            }

            if (strlen($row['pemPath']) > 4) {
                $in[] = '%PEMPATH%';
                $out[] = $row['pemPath'];
            }

            $vhost = "#\n# Registro da tabela ServicosHostingHttpdOriginal ID:{$row['id']}\n#\n";
            $vhost .= trim((str_replace($in, $out, $row['vhost']))) . "\n\n";
            $buffer .= $vhost;

            if (is_array($this->multi_domain)) {
                $this->multi_domain[$obj->dadosDominio['Dominio']] = str_replace("\r\n", "\n", $vhost);
            }

            $this->cache_vhosts_original[] = "{$row['idCliente']}_{$row['idDominio']}";
            unset($obj);
        }

        if (is_array($this->multi_domain) AND strlen($this->registro_httpd_original)) {
            $this->multi_domain['httpd.original'] = str_replace("\r\n", "\n", $this->registro_httpd_original);
        }

        $this->apache_conf .= $buffer;
        return $buffer;
    }

