        $variaveis['SERVER_ALIAS'] .= " ServerAlias www." . $this->dados_dominio['Dominio'] . " *." . $this->dados_dominio['Username'] . "." . $this->hostname_full . "\n";

        if ($this->fpm AND !$this->dados_dominio['Zope'] AND !$subdominio_excessao AND (($this->config['tipo_cliente'] == 'C' AND $this->dados_dominio['PHP'] > 0) OR $this->config['tipo_cliente'] == 'R')) {
            $variaveis['SERVER_ALIAS'] .= "     ServerAlias www." . $this->dados_dominio['Dominio'] . " *." . $this->dados_dominio['Dominio'] . "\n";
            $variaveis['SERVER_ALIAS'] .= "     ServerAlias www." . $this->dados_dominio['Dominio'] . " *." . $this->dados_dominio['Username'] . "." . $this->hostname_full . "\n";
        }

        if ($this->adicionais['mapeamentos']) {
            foreach ($this->adicionais['mapeamentos'] as $mapeamento) {
                $variaveis['SERVER_ALIAS'] .= " ServerAlias www." . $this->dados_dominio['Dominio'] . " " . $mapeamento['Mapeamento'] . "\n";
                $variaveis['SERVER_ALIAS'] .= " ServerAlias www." . $this->dados_dominio['Dominio'] . " *." . $mapeamento['Mapeamento'] . "\n";
            }
        }

        $variaveis['SERVER_ALIAS_PRINCIPAL'] = $variaveis['SERVER_ALIAS'];

        $template_conf = '';

        $subs = array();
        foreach ($ips_subdominios as $data) {
            $subs[] = $data['SubDominio'];
        }

        $rails_ssl = array();
        if (count($variaveis['RAILS_SUBDOMINIO'])) {
            foreach ($variaveis['RAILS_SUBDOMINIO'] as $subdominio) {

                $variaveis['IPS_LISTEN'] = "*:80";
                $variaveis['SUBDOMINIO'] = $subdominio;

                if ($apache_24) {
                    $variaveis['GRANT_RAILS'] = "
                        <Directory /home/{$this->dados_dominio['Username']}/apps_rails/{$subdominio}/public/>
                            Options -Indexes +FollowSymLinks
                            AllowOverride All
                            Require all granted
                        </Directory>
                    ";
                }
                $template_conf .= $this->template($variaveis, $this->templates_vhosts['SUBDOMINIO-RAILS']) . "\n\n";
                if(count($this->adicionais['ssl'][$subdominio]) && is_array($this->adicionais['ssl'][$subdominio]) && isset($this->adicionais['ssl'][$subdominio]['LetsEncrypt'])){
                    $rails_ssl[] = $subdominio;
                    $variaveis['IPS_LISTEN'] = $variaveis["IP_SNI"];
                    $variaveis['SSL'] = $this->monta_ssl_config($subdominio);
                    if($apache_24){
                        $variaveis['HTTP2_CONFIG'] = '
                            <Ifmodule http2_module>
                                Protocols h2 http/1.1
                            </Ifmodule>';
                    }
                    $template_conf .= $this->template($variaveis, $this->templates_vhosts['SUBDOMINIO-RAILS']) . "\n\n";
                }
                // Antes de configurar o vhost da 80 do subdominio do rails, certificar que de fato que nao vai colocar as configs de ssl de um possivel subdominio anterior configurado
                unset($variaveis['SSL']);
                unset($variaveis['HTTP2_CONFIG']);
                $subs[] = $subdominio;
            }
        }


        //IPs do subdominio seguem o do WWW (sem SSL)
        $force_ip_sub = '';
        $explode = explode(' ', $variaveis['IP_WWW']);
        foreach ($explode as $parte) {
            if (preg_match('/\:80$/', $parte)) {
                $force_ip_sub .= ' ' . $parte;
            }
        }

        //Subdominios (geral)
        if (is_array($this->adicionais['subdominios']) AND count($this->adicionais['subdominios'])) {
            foreach ($this->adicionais['subdominios'] as $dados_subdominio) {
                if (in_array($dados_subdominio['SubDominio'], $subs)) {
                    continue;
                }

                $variaveis['FPM_CONFIG'] = '';
                
                $variaveis['MOD_LIMITIPCONN'] = '';
                if ($dados_subdominio['varnish']) {
                    $variaveis['MOD_LIMITIPCONN'] = '<IfModule mod_limitipconn.c>
                     NoIPLimit /*
                     </IfModule>'; 
                }

                $variaveis['SERVER_ALIAS'] = '';
                if ($this->adicionais['mapeamentos']) {
                    foreach ($this->adicionais['mapeamentos'] as $mapeamento) {
                        $variaveis['SERVER_ALIAS'] .= " ServerAlias " . $dados_subdominio['SubDominio'] . "." . $mapeamento['Mapeamento'] . " www." . $dados_subdominio['SubDominio'] . "." . $mapeamento['Mapeamento'] . " \n";
                    }
                }

                $excecoes = $this->monta_excecoes_vhost($dados_subdominio['SubDominio']);


                if (trim($excecoes)) {
                    $variaveis['EXCECOES'] = $this->processa_variavel_execoes($excecoes);
                }

                $variaveis['SUBDOMINIO'] = $dados_subdominio['SubDominio'];
                $variaveis['SUB_DIR'] = $dados_subdominio['Diretorio'];

                $variaveis['FPM_CONFIG'] = '';
                if ($this->fpm AND (($this->config['tipo_cliente'] == 'C' AND $this->dados_dominio['PHP'] > 0) OR $this->config['tipo_cliente'] == 'R')) {
                    $variaveis['FPM_CONFIG'] = $this->fpm_config("{$dados_subdominio['SubDominio']}-{$this->dados_dominio['Username']}");
                }

                $variaveis['IPS_LISTEN'] = '*:80';

                if ($force_ip_sub) {
                    //$variaveis['IPS_LISTEN'] = $force_ip_sub;
                } else {
                    if ($this->server_dados['ipv6']) {
                        //$variaveis['IPS_LISTEN'] .= " [{$this->server_dados['ipv6']}]:80";
                    }
                }

                $template_conf .= $this->template($variaveis, $this->templates_vhosts['SUBDOMINIO-UNICO']) . "\n\n";
                $variaveis['MOD_LIMITIPCONN'] = '';
            }
            $variaveis['EXCECOES'] = '';
        }

        //Subdominio com IP's dedicados
        if (count($ips_subdominios)) {
            foreach ($ips_subdominios as $ip_subdominio) {
                $variaveis['SUBDOMINIO'] = $ip_subdominio['SubDominio'];
                $variaveis['SUB_DIR'] = $ip_subdominio['dados_sub']['Diretorio'];

                $excecoes = $this->monta_excecoes_vhost($ip_subdominio['SubDominio']);
                if (trim($excecoes)) {
                    $variaveis['EXCECOES'] = $this->processa_variavel_execoes($excecoes);
                }

                $variaveis['FPM_CONFIG'] = '';
                if ($this->fpm AND (($this->config['tipo_cliente'] == 'C' AND $this->dados_dominio['PHP'] > 0) OR $this->config['tipo_cliente'] == 'R')) {
                    $variaveis['FPM_CONFIG'] = $this->fpm_config("{$this->dados_dominio['Username']}-{$ip_subdominio['SubDominio']}");
                }

                $variaveis['SERVER_ALIAS'] = '';
                if ($this->adicionais['mapeamentos']) {
                    foreach ($this->adicionais['mapeamentos'] as $mapeamento) {
                        $variaveis['SERVER_ALIAS'] .= " ServerAlias " . $ip_subdominio['SubDominio'] . "." . $mapeamento['Mapeamento'] . " www." . $ip_subdominio['SubDominio'] . "." . $mapeamento['Mapeamento'] . " \n";
                    }
                }

                //Se tiver IPV6 habilitado , coloca tambem o IPV6 no vhost do subdominio
                $ipv6_do_subdominio_80 = '';
                $ipv6_do_subdominio_443 = '';
                if ($ip_subdominio['ipv6']) {
                    $ipv6_do_subdominio_80 = $ip_subdominio['ipv6'] . ':80';
                    $ipv6_do_subdominio_443 = $ip_subdominio['ipv6'] . ':443';
                }


                $variaveis['IPS_LISTEN'] = "{$ip_subdominio['Ip']}:80  {$ip_subdominio['IpInterno']}:80 {$ipv6_do_subdominio_80}";
                if ($ip_subdominio['Ip'] == $this->server_dados['ipExterno']) {
                    $variaveis['IPS_LISTEN'] = '*:80';
                }

                if (!preg_match('/apache/i', $this->dados_dominio['ServidorWeb'])) {
                    $variaveis['IPS_LISTEN'] = "*:80";
                }

                //Subdomínio na porta 80 (Sem SSL)
                $template_conf .= $this->template($variaveis, $this->templates_vhosts['SUBDOMINIO-UNICO']) . "\n\n";
                $excecoes_old = $variaveis['EXCECOES'];

                if ($ip_subdominio['ssl']) {
                    // se o cliente tem o subdominio do rails com ssl ja configurado, nao configura novamente
                    if(in_array($ip_subdominio['SubDominio'], $rails_ssl)) continue;
                    //Se nao tem as linhas do ssl, nao insere o vhost
                    if (!$this->tem_ssl_nas_diretivas($excecoes)) {

                        $conf_ssl = $this->monta_ssl_config($ip_subdominio['SubDominio'], $tem_pagespeed);

                        if (!strlen($conf_ssl)) {
                            continue;
                        }
                        $variaveis['EXCECOES'] .= $conf_ssl;

                    }

                    if ($apache_24) {
                        $variaveis['HTTP2_CONFIG'] = '
                            <Ifmodule http2_module>
                                Protocols h2 http/1.1
                            </Ifmodule>';
                    }

                    $variaveis['FPM_CONFIG'] = '';
                    if ($this->fpm AND (($this->config['tipo_cliente'] == 'C' AND $this->dados_dominio['PHP'] > 0) OR $this->config['tipo_cliente'] == 'R')) {
                        $variaveis['FPM_CONFIG'] = $this->fpm_config("{$this->dados_dominio['Username']}-{$ip_subdominio['SubDominio']}-ssl-novo");
                    }

                    //POIS O CLIENTE PODE JA TER AS EXCECOES CONFIGURADAS COM OS DADOS DO SSL
                    if (!$variaveis['EXCECOES']) {
                        if (trim($excecoes)) {
                            $variaveis['EXCECOES'] = $excecoes;
                        }
                    }


                    $variaveis['IPS_LISTEN'] = "{$ip_subdominio['Ip']}:443  {$ip_subdominio['IpInterno']}:443 {$ipv6_do_subdominio_443}";
                    if ($ip_subdominio['Ip'] == $this->server_dados['ipExterno']) {
                        $variaveis['IPS_LISTEN'] = $variaveis['IP_SNI'];
                    }

                    if (!preg_match('/apache/i', $this->dados_dominio['ServidorWeb'])) {
                        $variaveis['IPS_LISTEN'] = "*:443";
                    }

                    //Subdomínio na porta 443 (Com SSL)
                    $template_conf .= $this->template($variaveis, $this->templates_vhosts['SUBDOMINIO-UNICO']) . "\n\n";
                }

                $variaveis['EXCECOES'] = $excecoes_old;

            }
            $variaveis['EXCECOES'] = '';
        }

        if ($this->dados_dominio['Zope'] AND is_array($this->adicionais['zope']) AND count($this->adicionais['zope'])) {
            $variaveis['IPS_LISTEN'] = "*:80";
            $template_conf .= $this->template($variaveis, $this->templates_vhosts['SUBDOMINIO-ZOPE']) . "\n\n";
        }

        //WWW e @
        $excecoes = $this->monta_excecoes_vhost();
        if (trim($excecoes)) {
            $variaveis['EXCECOES'] = $excecoes;
        }

        $portas_listen = $this->separa_porta_listen($variaveis['IP_WWW']);
        //mod LIMITIPCONN
        $variaveis['MOD_LIMITIPCONN'] = '';
        if ($this->dados_dominio['varnish']) {
            $variaveis['MOD_LIMITIPCONN'] = '<IfModule mod_limitipconn.c>
             NoIPLimit /*
             </IfModule>'; 
        }


        $tem_lets_arroba = ($variaveis['SNI_FORCE_DOMAIN'] && $variaveis['SubDominio'] == '@' && $variaveis['LETSENCRYPT']);

        if (strlen($portas_listen['443'])) {
            //Aqui ele entra se tem tanto porta 80 quanto 443

            $excecoes_tmp = $variaveis['EXCECOES'];
            $nodejs_tmp = $variaveis['NODEJS_CONFIG_SSL'];
            $variaveis['NODEJS_CONFIG_SSL'] = '';

            //Porta 80
            $variaveis['IPS_LISTEN'] = $portas_listen['80'];
            $variaveis['EXCECOES'] = $this->processa_variavel_execoes($variaveis['EXCECOES']);
            if ($this->fpm AND (($this->config['tipo_cliente'] == 'C' AND $this->dados_dominio['PHP'] > 0) OR $this->config['tipo_cliente'] == 'R')) {
                $variaveis['FPM_CONFIG'] = $this->fpm_config($this->dados_dominio['Username']);
            }

            if (strlen($variaveis['IP_WWW_SNI'])) {
                $variaveis['IPS_LISTEN'] = '*:80';
            }

            //Monta o template da porta 80
            $template_conf .= $this->template($variaveis, $this->templates_vhosts['DOMINIO']) . "\n\n";

            //verificamos se tem ssl pra www ou @
            $tem_ssl = $this->tem_ssl_nas_diretivas($excecoes_tmp);
            if (!$tem_ssl) {
                $conf_ssl = $this->monta_ssl_config('www', $tem_pagespeed);
                if (!strlen($conf_ssl)) {
                    $conf_ssl = $this->monta_ssl_config('@', $tem_pagespeed);
                }
                if (strlen($conf_ssl)) {
                    if ($variaveis['LETSENCRYPT']) {
                        $variaveis['SERVER_ALIAS'] = '';
                        $variaveis['SERVER_ALIAS_PRINCIPAL'] = '';
                    }
                    $tem_ssl = true;
                    $excecoes_tmp .= $conf_ssl;
                }
            }

            //Porta 443 (so configura se tiver os paths do certificado instalados)
            if ($tem_ssl) {
                $variaveis['EXCECOES'] = $excecoes_tmp;
                $variaveis['IPS_LISTEN'] = $portas_listen['443'];
                $variaveis['NODEJS_CONFIG_SSL'] = $nodejs_tmp;

                $nodejs_tmp = $variaveis['NODEJS_CONFIG'];
                $variaveis['NODEJS_CONFIG'] = '';

                //Patch para wsgi
                $wsgi_tmp = '';
                if (strlen($variaveis['WSGI_CONFIG'])) {
                    $wsgi_tmp = $variaveis['WSGI_CONFIG'];

                    $in[] = "WSGIDaemonProcess www." . $this->dados_dominio['Dominio'];
                    $in[] = "WSGIProcessGroup www." . $this->dados_dominio['Dominio'];

                    $out[] = "WSGIDaemonProcess www." . $this->dados_dominio['Dominio'] . '.ssl';
                    $out[] = "WSGIProcessGroup www." . $this->dados_dominio['Dominio'] . '.ssl';

                    $variaveis['WSGI_CONFIG_SSL'] = str_replace($in, $out, $variaveis['WSGI_CONFIG']);
                    $variaveis['WSGI_CONFIG'] = '';
                }

                if ($apache_24) {
                    $variaveis['HTTP2_CONFIG'] = '
                            <Ifmodule http2_module>
                                Protocols h2 http/1.1
                            </Ifmodule>';
                }

                if ($this->fpm AND (($this->config['tipo_cliente'] == 'C' AND $this->dados_dominio['PHP'] > 0) OR $this->config['tipo_cliente'] == 'R')) {
                    $variaveis['FPM_CONFIG'] = $this->fpm_config("{$this->dados_dominio['Username']}-ssl-novo");
                }

                if (strlen($variaveis['IP_WWW_SNI'])) {
                    $variaveis['IPS_LISTEN'] = $variaveis['IP_WWW_SNI'];
                }

                if($variaveis['LETSENCRYPT'] AND false == $tem_lets_arroba) {
                    $variaveis['SERVER_ALIAS_CUSTOM'] = 'ServerAlias ' . $this->dados_dominio['Dominio'];
                }

                //patch cartão selvagem
                if($this->adicionais['ssl']['www'][0]['Wildcard'] == 'Sim'){
                    $variaveis['SERVER_ALIAS_CUSTOM'] = 'ServerAlias ' . $this->dados_dominio['Dominio'] . ' *.' . $this->dados_dominio['Dominio'];
                }

                //Monta o template da porta 443/SSL
                $template_conf .= $this->template($variaveis, $this->templates_vhosts['DOMINIO']) . "\n\n";

                $variaveis['NODEJS_CONFIG'] = $nodejs_tmp;

                if (strlen($wsgi_tmp)) {
                    $variaveis['WSGI_CONFIG'] = $wsgi_tmp;
                }
            }

        } else {
            //Aqui é se o cliente tem única e exclusivamente a porta 80
            $variaveis['NODEJS_CONFIG_SSL'] = '';
            $variaveis['IPS_LISTEN'] = $variaveis['IP_WWW'];
            if ($this->fpm AND (($this->config['tipo_cliente'] == 'C' AND $this->dados_dominio['PHP'] > 0) OR $this->config['tipo_cliente'] == 'R')) {
                $variaveis['FPM_CONFIG'] = $this->fpm_config($this->dados_dominio['Username']);
            }
            $template_conf .= $this->template($variaveis, $this->templates_vhosts['DOMINIO']) . "\n\n";
        }

        //SSL LetsEncrypt www
        $tmp_template = '';
        if ($variaveis['SNI_FORCE_DOMAIN'] && $variaveis['SubDominio'] == 'www' && $variaveis['LETSENCRYPT']) {
            $variaveis['EXCECOES'] = '';

            $variaveis['IPS_LISTEN'] = $variaveis['IP_WWW_SNI'];
            $variaveis['SSL'] = $this->monta_ssl_config('@', $tem_pagespeed);
            unset($variaveis['SERVER_ALIAS_PRINCIPAL']);
            if ($this->fpm AND (($this->config['tipo_cliente'] == 'C' AND $this->dados_dominio['PHP'] > 0) OR $this->config['tipo_cliente'] == 'R')) {
                $variaveis['FPM_CONFIG'] = $this->fpm_config($this->dados_dominio['Username'] . '-www-dominio-ssl-novo');
            }
            $variaveis['DOMINIO'] = $variaveis['SNI_FORCE_DOMAIN'];

            //Patch para wsgi
            $wsgi_tmp = '';
            if (strlen($variaveis['WSGI_CONFIG'])) {
                $wsgi_tmp = $variaveis['WSGI_CONFIG'];

                $in[] = "WSGIDaemonProcess www." . $this->dados_dominio['Dominio'];
                $in[] = "WSGIProcessGroup www." . $this->dados_dominio['Dominio'];
                $out[] = "WSGIDaemonProcess www." . $this->dados_dominio['Dominio'] . '.ssl';
                $out[] = "WSGIProcessGroup www." . $this->dados_dominio['Dominio'] . '.ssl';

                $variaveis['WSGI_CONFIG'] = str_replace($in, $out, $variaveis['WSGI_CONFIG']);
            }

            $excecoes = trim($this->monta_excecoes_vhost('www'));
            if ($excecoes) {
                $variaveis['EXCECOES'] = $excecoes;
            }

            if ($apache_24) {
                $variaveis['HTTP2_CONFIG'] = '
                            <Ifmodule http2_module>
                                Protocols h2 http/1.1
                            </Ifmodule>';
            }

            //Letsencrypt www também certifica @
            if(!$tem_lets_arroba) {
                $variaveis['SERVER_ALIAS_CUSTOM'] = 'ServerAlias ' . $this->dados_dominio['Dominio'];
            }

            $tmp_template .= $this->template($variaveis, $this->templates_vhosts['DOMINIO']);
            $out = array("www.{$variaveis['SNI_FORCE_DOMAIN']}");
            $in = array($variaveis['SNI_FORCE_DOMAIN']);
            $tmp_template = str_replace($out, $in, $tmp_template);

            $template_conf .= $tmp_template;
            $variaveis['WSGI_CONFIG'] = $wsgi_tmp;
            unset($tmp_template);
            unset($wsgi_tmp);
        }

        //SSL LetsEncrypt @
        $tmp_template = '';
        if ($variaveis['SNI_FORCE_DOMAIN'] && $variaveis['SubDominio'] == '@' && $variaveis['LETSENCRYPT']) {
            $variaveis['EXCECOES'] = '';

            $variaveis['IPS_LISTEN'] = $variaveis['IP_WWW_SNI'];
            $variaveis['SSL'] = $this->monta_ssl_config('@', $tem_pagespeed);
            unset($variaveis['SERVER_ALIAS_PRINCIPAL']);
            if ($this->fpm AND (($this->config['tipo_cliente'] == 'C' AND $this->dados_dominio['PHP'] > 0) OR $this->config['tipo_cliente'] == 'R')) {
                $variaveis['FPM_CONFIG'] = $this->fpm_config($this->dados_dominio['Username'] . '-arroba-dominio-ssl-novo');
            }

            $variaveis['DOMINIO'] = $variaveis['SNI_FORCE_DOMAIN'];

            $excecoes = trim($this->monta_excecoes_vhost('@'));
            if ($excecoes) {
                $variaveis['EXCECOES'] = $excecoes;
            }

            //Patch para wsgi
            $wsgi_tmp = '';
            if (strlen($variaveis['WSGI_CONFIG'])) {
                $wsgi_tmp = $variaveis['WSGI_CONFIG'];

                $in[] = "WSGIDaemonProcess www." . $this->dados_dominio['Dominio'];
                $in[] = "WSGIProcessGroup www." . $this->dados_dominio['Dominio'];
                $out[] = "WSGIDaemonProcess www." . $this->dados_dominio['Dominio'] . '.ssl';
                $out[] = "WSGIProcessGroup www." . $this->dados_dominio['Dominio'] . '.ssl';

                $variaveis['WSGI_CONFIG'] = str_replace($in, $out, $variaveis['WSGI_CONFIG']);
            }

            if ($apache_24) {
                $variaveis['HTTP2_CONFIG'] = '
                            <Ifmodule http2_module>
                                Protocols h2 http/1.1
                            </Ifmodule>';
            }

            $tmp_template .= $this->template($variaveis, $this->templates_vhosts['DOMINIO']);
            $out = array("www.{$variaveis['SNI_FORCE_DOMAIN']}");
            $in = array($variaveis['SNI_FORCE_DOMAIN']);
            $tmp_template = str_replace($out, $in, $tmp_template);
            $template_conf .= $tmp_template;
            $variaveis['WSGI_CONFIG'] = $wsgi_tmp;
            unset($tmp_template);
            unset($wsgi_tmp);
        }

        //SSL Compartilhado
        $tmp_template = '';
        if ($variaveis['SNI_FORCE_DOMAIN'] && !$variaveis['LETSENCRYPT']) {

            $variaveis['EXCECOES'] = '';
            $variaveis['IPS_LISTEN'] = $variaveis['IP_WWW_SNI'];

            $special_conf = array();
            $special_conf[] = "SSLVerifyDepth 10";
            $special_conf[] = "SSLEngine on";
            $special_conf[] = "SSLCertificateFile /usr/local/ssl/{$this->rede}/{$this->rede}.pem";
            $special_conf[] = "SSLCACertificateFile /usr/local/ssl/{$this->rede}/{$this->rede}.ca";
            $special_conf[] = "";
            $special_conf[] = '<IfModule log_config_module>';
            $special_conf[] = '    LogFormat "' . $this->dados_dominio['Dominio'] . ' %h %l %u %t \"%r\" %>s %b \"%{Referer}i\" \"%{User-Agent}i\""';
            $special_conf[] = '    TransferLog /home/logs/access_log';
            $special_conf[] = '</IfModule>';

            $variaveis['SSL'] = implode("\n        ", $special_conf);

            unset($variaveis['SERVER_ALIAS_PRINCIPAL']);

            if ($this->fpm AND (($this->config['tipo_cliente'] == 'C' AND $this->dados_dominio['PHP'] > 0) OR $this->config['tipo_cliente'] == 'R')) {
                $variaveis['FPM_CONFIG'] = $this->fpm_config($this->dados_dominio['Username'] . '-ssl-compartilhado');
            }

            $variaveis['DOMINIO'] = $variaveis['SNI_FORCE_DOMAIN'];

            //Patch para wsgi
            $wsgi_tmp = '';
            if (strlen($variaveis['WSGI_CONFIG'])) {
                $wsgi_tmp = $variaveis['WSGI_CONFIG'];

                $in[] = "WSGIDaemonProcess www." . $this->dados_dominio['Dominio'];
                $in[] = "WSGIProcessGroup www." . $this->dados_dominio['Dominio'];

                $out[] = "WSGIDaemonProcess www." . $this->dados_dominio['Dominio'] . '.ssl';
                $out[] = "WSGIProcessGroup www." . $this->dados_dominio['Dominio'] . '.ssl';

                $variaveis['WSGI_CONFIG'] = str_replace($in, $out, $variaveis['WSGI_CONFIG']);
            }

            if ($apache_24) {
                $variaveis['HTTP2_CONFIG'] = '
                            <Ifmodule http2_module>
                                Protocols h2 http/1.1
                            </Ifmodule>';
            }

            $tmp_template .= $this->template($variaveis, $this->templates_vhosts['DOMINIO']);

            $out = array("www.{$variaveis['SNI_FORCE_DOMAIN']}");
            $in = array($variaveis['SNI_FORCE_DOMAIN']);
            $tmp_template = str_replace($out, $in, $tmp_template);

            $template_conf .= $tmp_template;

            $variaveis['WSGI_CONFIG'] = $wsgi_tmp;
            unset($tmp_template);
            unset($wsgi_tmp);
        }

        return $this->formata_vhost($template_conf) . "\n\n";
    }

    function separa_porta_listen($ips_listen)
    {
        $ips_listen = trim($ips_listen);
        $explode = explode(" ", $ips_listen);

        $porta80 = '';
        $porta443 = '';
        foreach ($explode as $strip) {
            $strip = trim($strip);
            $explode2 = explode(':', $strip);
            $porta = end($explode2);

            switch ($porta) {
                case '443':
                    $porta443 .= $strip . ' ';
                    break;
                default:
                    $porta80 .= $strip . ' ';
                    break;
            }
        }

        $r['80'] = trim($porta80);
        $r['443'] = trim($porta443);

        return $r;
    }

    function tem_ssl_nas_diretivas($excecoes)
    {
        $explode = explode("\n", trim($excecoes));

        $ret = 0;
        foreach ($explode as $linha) {
            if (preg_match('/SSLEngine/', $linha)) {
                $ret++;
            }
            if (preg_match('/SSLCertificateFile/', $linha)) {
                $ret++;
            }
            if (preg_match('/SSLCertificateKeyFile/', $linha)) {
                $ret++;
            }
            if (preg_match('/SSLCACertificateFile/', $linha)) {
                $ret++;
            }
        }

        if ($ret > 3) {
            return true;
        }
        return false;
    }

    function monta_ssl_config($subdominio, $tem_pagespeed=false)
    {
        if (is_array($this->adicionais['ssl'][$subdominio]) AND count($this->adicionais['ssl'][$subdominio])) {
            $dados_ssl = $this->adicionais['ssl'][$subdominio][0];
            $dominio = ($dados_ssl['Host']) ? $dados_ssl['Host'] : $this->dados_dominio['Dominio'];
            $dominio = str_replace('www.', '', $dominio);
            $full_domain = "{$subdominio}.{$dominio}";
            $full_domain = str_replace('@.', '', $full_domain);

            $ssl_ini = "
                # Bloqueia SSL de baixa criptografia
                SSLProtocol all -SSLv2 -SSLv3
                SSLHonorCipherOrder on
                SSLCipherSuite ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-AES128-SHA256:ECDHE-RSA-AES128-SHA256:ECDHE-ECDSA-AES128-SHA:ECDHE-RSA-AES256-SHA384:ECDHE-RSA-AES128-SHA:ECDHE-ECDSA-AES256-SHA384:ECDHE-ECDSA-AES256-SHA:ECDHE-RSA-AES256-SHA:DHE-RSA-AES128-SHA256:DHE-RSA-AES128-SHA:DHE-RSA-AES256-SHA256:DHE-RSA-AES256-SHA:ECDHE-ECDSA-DES-CBC3-SHA:EDH-RSA-DES-CBC3-SHA:!DSS:!3DES
            ";
            
            $ssl = "
                SSLVerifyDepth 10
                SSLEngine on
                SSLCertificateFile {$this->ssl_path}/{$dominio}/{$full_domain}.pem
                SSLCACertificateFile {$this->ssl_path}/{$dominio}/{$full_domain}.ca
            ";

            //Se for letsencrypt
            if ($dados_ssl['LetsPath'] || $this->adicionais['ssl']['www'][0]['Wildcard'] == 'Sim') {
                // usa o caminho do wildcard no www, resolve erro 421 pelo caminho ser diferente
                if ($this->adicionais['ssl']['www'][0]['Wildcard'] == 'Sim') {
                    $lets_path = end(explode('/', $this->adicionais['ssl']['www'][0]['LetsPath']));
                } else {
                    $lets_path = end(explode('/', $dados_ssl['LetsPath']));
                }

                $ssl = "
                    SSLVerifyDepth 10
                    SSLEngine on
                    SSLCertificateFile /etc/letsencrypt/live/{$lets_path}/cert.pem
                    SSLCertificateKeyFile /etc/letsencrypt/live/{$lets_path}/privkey.pem
                    SSLCACertificateFile /etc/letsencrypt/live/{$lets_path}/chain.pem
                        ";
            }

            if($tem_pagespeed){
                $ssl .= "
                    <IfModule pagespeed_module>
                        ModPagespeedMapOriginDomain http://{$full_domain} https://{$full_domain}
                    </IfModule>
                ";
            }

            //Apache 2.4
            if ($this->servidor_tem_suporte('APACHE2.4')) {
                $ssl .= "
                    SSLCompression off
                    SSLUseStapling off
                ";
            }

            return $ssl_ini . $ssl;
        }

        return '';
    }

    function processa_variavel_execoes($excecoes)
    {
        $explode = explode("\n", trim($excecoes));
        $excecoes = '';
        foreach ($explode as $linha) {
            if (preg_match('/^SSL/', $linha)) {
                $excecoes .= preg_replace('/^SSL/i', '#SSL', $linha) . "\n";
            } else {
                $excecoes .= $linha . "\n";
            }
        }

        return $excecoes;
    }

