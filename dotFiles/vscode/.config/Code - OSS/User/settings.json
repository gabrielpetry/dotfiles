{
    "editor.fontFamily": "\"Hack\", 'Cascadia Code', 'monospace', monospace, 'Droid Sans Fallback'",
    "editor.rulers": [80,120],
    "editor.fontLigatures": true,
    "editor.lineHeight": 23,
    "window.zoomLevel": 1,
    "workbench.iconTheme": "material-icon-theme",
    "vim.camelCaseMotion.enable": true,
    "keyboard.dispatch": "keyCode",
    "editor.tabCompletion": "on",
    "editor.acceptSuggestionOnCommitCharacter": false,
    "editor.suggestOnTriggerCharacters": false,
    "editor.cursorSmoothCaretAnimation": true,
    "editor.smoothScrolling": true,
    "workbench.colorTheme": "Nordico",
    "telemetry.enableCrashReporter": false,
    "telemetry.enableTelemetry": false,
    "vim.neovimPath": "/usr/bin/nvim",
    "vim.enableNeovim": true,
    "git.autofetch": true,
    "powermode.enabled": true,
    "powermode.presets": "simple-rift",
    "editor.suggestSelection": "first",
    "vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",
    "editor.formatOnSave": true,
    "editor.formatOnSaveTimeout": 5000,
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "eslint.autoFixOnSave": true,
    "explorer.confirmDelete": false,
    "javascript.format.insertSpaceAfterOpeningAndBeforeClosingNonemptyBrackets": true,
    "typescript.format.insertSpaceAfterOpeningAndBeforeClosingNonemptyBrackets": true,
    "vim.foldfix": true,
    "latex-workshop.view.pdf.viewer": "tab",
    "editor.fontSize": 12,
    "editor.codeActionsOnSave": {
        "source.fixAll.eslint": true
    },
    "files.autoGuessEncoding": true,
    "editor.fontWeight": "600",
    "php-cs-fixer.pathMode": "override",
    "php-cs-fixer.configFile": ".php_cs",
    "php-cs-fixer.executable": "/usr/local/bin/php-cs-fixer --allow-risky=yes",
    "editor.tabSize": 2,
    "sonarlint.ls.javaHome": "/home/petry/.vscode-oss/extensions/sonarsource.sonarlint_managed-jre/jre/jdk-11.0.6+10-jre"
}